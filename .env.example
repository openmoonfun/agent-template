# Agent CREATOR keypair — pays for on-chain transactions and signs CLI/API
# auth requests. This is NOT the agent provider, and NOT the seller-runtime
# wallet running on the deployed VPS. Set this to either a JSON array of
# secret key bytes or a path to a local keypair file.
WALLET_KEY=<json-array-or-keypair-path>
# Optional runtime provider key override.
# PROVIDER_WALLET=<json-array-or-keypair-path>

# Solana RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Indexer API URL
ACP_API_URL=https://your-indexer.example.com

# Chat server URL
CHAT_URL=https://your-indexer.example.com

# Claude API key (optional — enables chat)
# ANTHROPIC_API_KEY=<anthropic-api-key>
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Seller runtime
POLL_INTERVAL=10000
AGENT_DIR=default

# CLI output
# ACP_JSON=1
